# Configuration for Docker on Linux
# Use this when running services in Docker on Linux

# LLM Provider selection
LLM_PROVIDER=ollama

# Ollama configuration (running on host machine)
OLLAMA_HOST=http://172.17.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# LLM configuration
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0

# Decision Engine configuration (running on host machine)
DECISION_ENGINE_HOST=http://172.17.0.1:8080

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_OUTPUT=console
LOG_FILE_PATH=logs/llm_service.log