# Ollama configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# LLM configuration
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_OUTPUT=console
LOG_FILE_PATH=logs/llm_service.log