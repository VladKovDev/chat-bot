# LLM Provider selection (ollama, gigachat)
LLM_PROVIDER=ollama

# Ollama configuration
# For Docker on Linux use 172.17.0.1, for local development use localhost
# For Docker Desktop (Mac/Windows) you can use host.docker.internal
OLLAMA_HOST=http://172.17.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# GigaChat configuration
# Get your credentials from: https://developers.sber.ru/docs/ru/gigachat
GIGACHAT_CREDENTIALS=your_base64_encoded_credentials_here
GIGACHAT_MODEL=GigaChat
# GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/  # Default (personal)
# GIGACHAT_BASE_URL=https://api.giga.chat/  # Business
GIGACHAT_SCOPE=GIGACHAT_API_PERS  # GIGACHAT_API_PERS, GIGACHAT_API_B2B, or GIGACHAT_API_CORP
GIGACHAT_JSON_MODE=true  # Force JSON responses using response_format parameter

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# LLM configuration
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0

# Decision Engine configuration
DECISION_ENGINE_HOST=http://localhost:8080

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_OUTPUT=console
LOG_FILE_PATH=logs/llm_service.log