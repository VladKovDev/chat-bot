{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Website WebSocket v1 Contracts",
  "type": "object",
  "required": ["client_events", "server_events", "$defs"],
  "client_events": {
    "session.start": { "$ref": "#/$defs/sessionStartEvent" },
    "message.user": { "$ref": "#/$defs/messageUserEvent" },
    "quick_reply.selected": { "$ref": "#/$defs/quickReplySelectedEvent" },
    "operator.close": { "$ref": "#/$defs/operatorCloseEvent" }
  },
  "server_events": {
    "session.started": { "$ref": "#/$defs/sessionStartedEvent" },
    "message.bot": { "$ref": "#/$defs/messageBotEvent" },
    "message.operator": { "$ref": "#/$defs/messageOperatorEvent" },
    "handoff.queued": { "$ref": "#/$defs/handoffEvent" },
    "handoff.accepted": { "$ref": "#/$defs/handoffEvent" },
    "handoff.closed": { "$ref": "#/$defs/handoffEvent" },
    "error": { "$ref": "#/$defs/errorEvent" }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "uuid": {
      "type": "string"
    },
    "baseEvent": {
      "type": "object",
      "required": ["type", "event_id", "correlation_id", "timestamp"],
      "properties": {
        "type": { "type": "string" },
        "session_id": { "type": "string" },
        "event_id": { "type": "string" },
        "correlation_id": { "type": "string" },
        "timestamp": { "$ref": "#/$defs/timestamp" }
      }
    },
    "quickReply": {
      "type": "object",
      "required": ["id", "label", "action"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "action": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "required": ["handoff_id", "session_id", "status"],
      "properties": {
        "handoff_id": { "type": "string" },
        "session_id": { "type": "string" },
        "status": { "type": "string" },
        "reason": { "type": "string" },
        "operator_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "publicError": {
      "type": "object",
      "required": ["code", "message", "request_id"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "request_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sessionStartEvent": {
      "allOf": [
        { "$ref": "#/$defs/baseEvent" },
        {
          "type": "object",
          "required": ["type", "client_id"],
          "properties": {
            "type": { "const": "session.start" },
            "client_id": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "messageUserEvent": {
      "allOf": [
        { "$ref": "#/$defs/baseEvent" },
        {
          "type": "object",
          "required": ["type", "session_id", "text"],
          "properties": {
            "type": { "const": "message.user" },
            "session_id": { "type": "string" },
            "text": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "quickReplySelectedEvent": {
      "allOf": [
        { "$ref": "#/$defs/baseEvent" },
        {
          "type": "object",
          "required": ["type", "session_id", "quick_reply"],
          "properties": {
            "type": { "const": "quick_reply.selected" },
            "session_id": { "type": "string" },
            "quick_reply": { "$ref": "#/$defs/quickReply" }
          },
          "additionalProperties": false
        }
      ]
    },
    "operatorCloseEvent": {
      "allOf": [
        { "$ref": "#/$defs/baseEvent" },
        {
          "type": "object",
          "required": ["type", "session_id"],
          "properties": {
            "type": { "const": "operator.close" },
            "session_id": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "sessionStartedEvent": {
      "allOf": [
        { "$ref": "#/$defs/baseEvent" },
        {
          "type": "object",
          "required": ["type", "session_id", "mode", "active_topic", "resumed"],
          "properties": {
            "type": { "const": "session.started" },
            "session_id": { "type": "string" },
            "mode": { "type": "string" },
            "active_topic": { "type": ["string", "null"] },
            "resumed": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "messageBotEvent": {
      "allOf": [
        { "$ref": "#/$defs/baseEvent" },
        {
          "type": "object",
          "required": ["type", "session_id", "message_id", "text", "mode", "active_topic"],
          "properties": {
            "type": { "const": "message.bot" },
            "session_id": { "type": "string" },
            "message_id": { "type": "string" },
            "text": { "type": "string" },
            "quick_replies": {
              "type": "array",
              "items": { "$ref": "#/$defs/quickReply" }
            },
            "mode": { "type": "string" },
            "active_topic": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "messageOperatorEvent": {
      "allOf": [
        { "$ref": "#/$defs/baseEvent" },
        {
          "type": "object",
          "required": ["type", "session_id", "message_id", "text"],
          "properties": {
            "type": { "const": "message.operator" },
            "session_id": { "type": "string" },
            "message_id": { "type": "string" },
            "operator_id": { "type": "string" },
            "text": { "type": "string" },
            "mode": { "type": "string" },
            "active_topic": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "handoffEvent": {
      "allOf": [
        { "$ref": "#/$defs/baseEvent" },
        {
          "type": "object",
          "required": ["type", "session_id", "handoff"],
          "properties": {
            "type": {
              "enum": ["handoff.queued", "handoff.accepted", "handoff.closed"]
            },
            "session_id": { "type": "string" },
            "handoff": { "$ref": "#/$defs/handoff" }
          },
          "additionalProperties": false
        }
      ]
    },
    "errorEvent": {
      "allOf": [
        { "$ref": "#/$defs/baseEvent" },
        {
          "type": "object",
          "required": ["type", "error"],
          "properties": {
            "type": { "const": "error" },
            "error": { "$ref": "#/$defs/publicError" }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
