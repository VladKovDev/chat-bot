{
  "transitions": [
    {
      "from": "standard",
      "event": "request_operator",
      "to": "waiting_operator",
      "response_key": "escalation_to_operator",
      "actions": ["escalate_to_operator"]
    },
    {
      "from": "waiting_operator",
      "event": "operator_connected",
      "to": "operator_connected",
      "response_key": "escalation_context_sent"
    },
    {
      "from": "waiting_operator",
      "event": "operator_closed",
      "to": "closed",
      "response_key": "goodbye"
    },
    {
      "from": "operator_connected",
      "event": "operator_closed",
      "to": "closed",
      "response_key": "goodbye"
    },
    {
      "from": "closed",
      "event": "reset_conversation",
      "to": "standard",
      "response_key": "start",
      "actions": ["reset_conversation"]
    }
  ],
  "global_events": {
    "reset_conversation": {
      "to": "standard",
      "response_key": "start",
      "actions": ["reset_conversation"]
    }
  }
}
