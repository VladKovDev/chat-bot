    },
    {
      "from": "new",
      "event": "greeting",
      "to": "waiting_for_category",
      "response_key": "start"
    },
    {
      "from": "waiting_for_category",
      "event": "category_selected",
      "to": "waiting_clarification",
      "response_key": "category_selected"
    },
    {
      "from": "waiting_for_category",
      "event": "message_received",
      "to": "waiting_clarification",
      "response_key": "category_selected"
    },
    {
      "from": "waiting_clarification",
      "event": "message_received",
      "to": "solution_offered",
      "response_key": "solution_offered"
    },
    {
      "from": "waiting_clarification",
      "event": "greeting",
      "to": "waiting_clarification",
      "response_key": "waiting_clarification"
    },
    {
      "from": "solution_offered",
      "event": "resolved",
